#!/bin/bash
# Versioned pre-commit hook. Activate per-clone with:
#   git config core.hooksPath .githooks
#
# Catches the failure modes documented in AGENTS.md > Implementation
# discipline. Specifically:
#   1. SyntaxError in any staged .py (AST parse)
#   2. Import-time NameError / circular import in staged src/ modules
#      (REAL import — the AST parse alone cannot see these)
#   3. Targeted test failure on a touched src/core or src/data file
#
# Bypass with --no-verify only when explicitly requested by the user.

set -e

# Colour codes (no-op on dumb terminals)
RED=$(tput setaf 1 2>/dev/null || true)
GREEN=$(tput setaf 2 2>/dev/null || true)
YELLOW=$(tput setaf 3 2>/dev/null || true)
RESET=$(tput sgr0 2>/dev/null || true)

# ────────────────────────────────────────────────────────────────────
# 1. Syntax + import smoke for every staged .py file
# ────────────────────────────────────────────────────────────────────
# A/M/R: renamed files list their NEW path — a renamed module must re-prove
# it parses and imports under its new name just like an added one.
staged_py=$(git diff --cached --name-only --diff-filter=AMR | grep '\.py$' || true)

if [ -z "$staged_py" ]; then
    # No Python files changed — nothing to verify
    exit 0
fi

echo "${YELLOW}pre-commit: syntax check on $(echo "$staged_py" | wc -l | tr -d ' ') file(s)${RESET}"

for f in $staged_py; do
    # AST parse — catches the "claimed-to-move-import-but-didn't" class
    # of regression. Open with utf-8 so files with Chinese comments
    # don't trip Windows GBK default.
    if ! python -c "
import ast, sys
src = open(sys.argv[1], encoding='utf-8').read()
try:
    ast.parse(src)
except SyntaxError as e:
    print(f'  SyntaxError in {sys.argv[1]}:{e.lineno}: {e.msg}')
    sys.exit(1)
" "$f"; then
        echo "${RED}pre-commit: syntax check FAILED on $f${RESET}"
        echo "${RED}fix the syntax error or run with --no-verify if intentional${RESET}"
        exit 1
    fi
done

# ────────────────────────────────────────────────────────────────────
# 2. REAL import smoke for every staged src/ module
#
# The AST parse above only catches SyntaxError. The failure mode
# AGENTS.md's discipline section documents — a removed-but-still-
# referenced symbol — is an import-time NameError, and circular
# imports are ImportError: both only surface when the module is
# ACTUALLY imported (backlog #5). Scope: src/ modules only (scripts/
# are one-shot probes not designed for bare import; tests import
# under pytest). All changed modules run in ONE interpreter so the
# heavy-dependency startup cost (pandas, lightgbm) is paid once.
# ────────────────────────────────────────────────────────────────────
changed_src=$(echo "$staged_py" | grep -E '^src/' || true)

if [ -n "$changed_src" ]; then
    # path -> import name: src/core/foo.py -> src.core.foo;
    # a package __init__.py imports as the package itself.
    modules=$(echo "$changed_src" \
        | sed -e 's/\.py$//' -e 's|/__init__$||' -e 's|/|.|g' \
        | sort -u)
    echo "${YELLOW}pre-commit: import smoke on $(echo "$modules" | wc -l | tr -d ' ') module(s)${RESET}"
    # Import the STAGED content, not the worktree: under partial staging the
    # two differ — a broken staged blob with a fixed-but-unstaged worktree
    # would pass a worktree import (and a clean staged blob would fail on
    # unrelated unstaged edits). Materializing the full index (~0.4s) also
    # keeps SIBLING modules consistent: every import in the smoke resolves
    # to exactly what this commit will contain.
    index_tree=$(mktemp -d)
    trap 'rm -rf "$index_tree"' EXIT
    git checkout-index -a --prefix="$index_tree/"
    if ! (cd "$index_tree" && PYTHONIOENCODING=utf-8 python -c "
import importlib, sys
failed = False
for m in sys.argv[1:]:
    try:
        importlib.import_module(m)
    except Exception as e:
        print(f'  import {m} FAILED: {type(e).__name__}: {e}')
        failed = True
sys.exit(1 if failed else 0)
" $modules); then
        echo "${RED}pre-commit: import smoke FAILED${RESET}"
        echo "${RED}a staged src/ module does not import cleanly (NameError /${RESET}"
        echo "${RED}circular import / missing dependency) — fix and re-stage${RESET}"
        exit 1
    fi
    rm -rf "$index_tree"
    trap - EXIT
fi

# ────────────────────────────────────────────────────────────────────
# 3. Targeted test run for any src/core/*.py or src/data/*.py touched
#
# The matching test_<basename>.py runs IF it exists. Heavy E2E tests
# (RUN_E2E=1) stay off — those need a qlib bundle and are CI-only.
# ────────────────────────────────────────────────────────────────────
test_files=""
for f in $(echo "$staged_py" | grep -E 'src/(core|data)/'); do
    base=$(basename "$f" .py)
    candidate="tests/logic/test_${base}.py"
    if [ -f "$candidate" ]; then
        test_files="$test_files $candidate"
    fi
done

if [ -n "$test_files" ]; then
    echo "${YELLOW}pre-commit: running targeted tests${RESET}"
    if ! python -m pytest -q $test_files; then
        echo "${RED}pre-commit: targeted tests FAILED${RESET}"
        echo "${RED}fix the regression before committing,${RESET}"
        echo "${RED}or run with --no-verify only if user explicitly asked${RESET}"
        exit 1
    fi
fi

echo "${GREEN}pre-commit: ok${RESET}"
exit 0
